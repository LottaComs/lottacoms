---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/components.css";
import { ViewTransitions } from "astro:transitions";
import { htmlLang } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = "LottaComs",
  description = "Software products and talent services for technology teams.",
  lang = "en",
} = Astro.props;

const pageTitle = title === "LottaComs" ? title : `${title} — LottaComs`;
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/logo-mark.svg" />
    <ViewTransitions />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-content font-sans antialiased">
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
