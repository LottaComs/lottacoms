---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="RoboLab" description="RoboLab — fleet management for autonomous mobile robots.">
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="max-w-xl mx-auto px-6 py-20 text-center">
      <div class="inline-flex items-center gap-2 bg-amber-100 text-amber-700 text-xs font-semibold px-3 py-1 rounded-full mb-6">
        <span class="w-2 h-2 bg-amber-400 rounded-full"></span>
        Coming soon
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">RoboLab</h1>
      <p class="text-xl text-gray-600 mb-8">
        Fleet management for autonomous mobile robots. The demo is on its way.
      </p>
      <a
        href="/products"
        class="inline-block border-2 border-brand-green-600 text-brand-green-700 font-semibold px-6 py-3 rounded-lg hover:bg-brand-green-50 transition-colors"
      >
        Back to Products
      </a>
    </div>
  </section>
</BaseLayout>
