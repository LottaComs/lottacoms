---
import BaseLayout from "../layouts/BaseLayout.astro";
import IconCheck from "../components/icons/IconCheck.astro";
---

<BaseLayout title="Message sent" lang="en">
  <section class="bg-white">
    <div class="max-w-2xl mx-auto px-6 py-32 text-center">
      <div class="icon-badge w-16 h-16 bg-brand-green-100 rounded-full mx-auto mb-6">
        <IconCheck class="w-8 h-8 text-brand-green-700" />
      </div>
      <h1 class="heading-section mb-4">Message sent</h1>
      <p class="text-lg text-content-body mb-8">
        Thanks for reaching out. We'll get back to you within one business day.
      </p>
      <a
        href="/"
        class="btn-primary"
      >
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>
