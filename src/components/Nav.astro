---
import {
  useTranslations,
  localePath,
  alternateUrl,
  locales,
  langLabels,
} from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: t("nav.products"), href: localePath(lang, "/products") },
  { label: t("nav.services"), href: localePath(lang, "/services") },
  { label: t("nav.about"), href: localePath(lang, "/about") },
];
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a
      href={localePath(lang, "/")}
      class="shrink-0"
      aria-label={t("nav.aria.home")}
    >
      <img src="/logo.svg" alt="LottaComs" class="h-14 w-auto" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map(({ label, href }) => (
          <a
            href={href}
            class:list={[
              "text-sm font-medium transition-colors",
              currentPath.startsWith(href)
                ? "text-brand-green-700"
                : "text-gray-600 hover:text-brand-green-700",
            ]}
          >
            {label}
          </a>
        ))
      }
      <a
        href={localePath(lang, "/contact")}
        class="bg-brand-gold text-brand-green-800 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-brand-gold-dark transition-colors"
      >
        {t("nav.contact")}
      </a>

      <!-- Language switcher -->
      <div
        class="flex items-center gap-2 text-xs font-semibold border-l border-gray-200 pl-4"
      >
        {
          locales.map((l) => (
            <a
              href={alternateUrl(currentPath, l)}
              hreflang={l}
              class:list={[
                "transition-colors",
                l === lang
                  ? "text-brand-green-700 cursor-default pointer-events-none"
                  : "text-gray-400 hover:text-brand-green-700",
              ]}
              aria-current={l === lang ? "true" : undefined}
            >
              {langLabels[l]}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-600 hover:text-brand-green-700"
      aria-label={t("nav.aria.toggle")}
      aria-expanded="false"
    >
      <svg
        id="icon-open"
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="icon-close"
        class="w-6 h-6 hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-100 bg-white px-6 py-4 flex-col gap-4"
  >
    {
      navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            "text-sm font-medium transition-colors",
            currentPath.startsWith(href)
              ? "text-brand-green-700"
              : "text-gray-600 hover:text-brand-green-700",
          ]}
        >
          {label}
        </a>
      ))
    }
    <a
      href={localePath(lang, "/contact")}
      class="inline-block bg-brand-gold text-brand-green-800 text-sm font-semibold px-4 py-2 rounded-lg text-center hover:bg-brand-gold-dark transition-colors"
    >
      {t("nav.contact")}
    </a>

    <!-- Mobile language switcher -->
    <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
      {
        locales.map((l) => (
          <a
            href={alternateUrl(currentPath, l)}
            hreflang={l}
            class:list={[
              "text-xs font-semibold transition-colors",
              l === lang
                ? "text-brand-green-700 cursor-default pointer-events-none"
                : "text-gray-400 hover:text-brand-green-700",
            ]}
          >
            {langLabels[l]}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    menu?.classList.toggle("flex", !isOpen);
    iconOpen?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
