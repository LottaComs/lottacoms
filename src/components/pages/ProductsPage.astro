---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";
import IconCheck from "../icons/IconCheck.astro";
import IconMonitor from "../icons/IconMonitor.astro";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout
  title={t("products.meta.title")}
  description={t("products.meta.description")}
  lang={lang}
>
  <!-- Header -->
  <section class="section-header">
    <div class="container-page py-16">
      <p class="eyebrow mb-3">
        {t("products.header.eyebrow")}
      </p>
      <h1 class="heading-page mb-4">{t("products.header.heading")}</h1>
      <p class="subtitle-page max-w-2xl">{t("products.header.body")}</p>
    </div>
  </section>

  <!-- RoboLab feature card -->
  <section class="bg-white">
    <div class="container-page py-20">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div>
          <div class="inline-flex items-center gap-2 bg-amber-100 text-amber-700 text-xs font-semibold px-3 py-1 rounded-full mb-6">
            <span class="w-2 h-2 bg-amber-400 rounded-full"></span>
            {t("products.robolab.badge")}
          </div>
          <h2 class="heading-section mb-4">{t("products.robolab.heading")}</h2>
          <p class="body-text text-lg mb-6">{t("products.robolab.body1")}</p>
          <p class="body-text mb-8">{t("products.robolab.body2")}</p>
          <div class="flex flex-wrap gap-3 mb-10">
            <a
              href="/robolab"
              class="btn-primary"
            >
              {t("products.robolab.cta.demo")}
            </a>
            <a
              href={localePath(lang, "/contact")}
              class="btn-secondary"
            >
              {t("footer.cta.button")}
            </a>
          </div>
        </div>

        <!-- Benefits list -->
        <div class="space-y-5">
          <h3 class="eyebrow text-content-muted font-semibold mb-6">
            {t("products.robolab.benefits.label")}
          </h3>
          {[
            { title: t("products.robolab.b1.title"), body: t("products.robolab.b1.body") },
            { title: t("products.robolab.b2.title"), body: t("products.robolab.b2.body") },
            { title: t("products.robolab.b3.title"), body: t("products.robolab.b3.body") },
            { title: t("products.robolab.b4.title"), body: t("products.robolab.b4.body") },
          ].map(({ title, body }) => (
            <div class="flex gap-4">
              <div class="icon-badge w-6 h-6 bg-brand-green-100 rounded-full mt-0.5">
                <IconCheck class="w-3.5 h-3.5 text-brand-green-700" strokeWidth="2.5" />
              </div>
              <div>
                <p class="font-semibold text-content mb-1">{title}</p>
                <p class="body-sm">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshot / demo placeholder -->
  <section class="section-accent border-y">
    <div class="container-page py-16">
      <div class="bg-brand-green-700 rounded-2xl aspect-video flex items-center justify-center">
        <div class="text-center text-green-200">
          <IconMonitor class="w-16 h-16 mx-auto mb-4 opacity-50" />
          <p class="font-medium">{t("products.demo.caption")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coming soon -->
  <section class="bg-white">
    <div class="container-page py-20">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3">
          {t("products.coming.eyebrow")}
        </p>
        <h2 class="heading-section">{t("products.coming.heading")}</h2>
        <p class="text-content-body mt-3 max-w-xl mx-auto">{t("products.coming.body")}</p>
      </div>
      <div class="border-2 border-dashed border-divider rounded-2xl p-12 text-center max-w-md mx-auto">
        <p class="text-4xl mb-4">🚧</p>
        <p class="font-semibold text-content mb-2">{t("products.coming.label")}</p>
        <p class="text-content-muted text-sm">{t("products.coming.sub")}</p>
      </div>
    </div>
  </section>
</BaseLayout>
