---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";
import IconCode from "../icons/IconCode.astro";
import IconUsers from "../icons/IconUsers.astro";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout
  title="LottaComs"
  description={t("home.meta.description")}
  lang={lang}
>
  <!-- Hero -->
  <section class="section-accent">
    <div class="container-page py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">
          {t("home.hero.eyebrow")}
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-content leading-tight mb-6">
          {t("home.hero.heading").split("\n").map((line, i) => (
            <>{i > 0 && <br />}{line}</>
          ))}
        </h1>
        <p class="subtitle-page mb-10 max-w-xl">
          {t("home.hero.body")}
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={localePath(lang, "/contact")}
            class="btn-primary"
          >
            {t("home.hero.cta.contact")}
          </a>
          <a
            href={localePath(lang, "/products")}
            class="btn-secondary"
          >
            {t("home.hero.cta.products")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="bg-white">
    <div class="container-page py-20">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3">
          {t("home.what.eyebrow")}
        </p>
        <h2 class="heading-section">{t("home.what.heading")}</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Software Products -->
        <div class="card-accent">
          <div class="icon-badge w-12 h-12 bg-brand-green-700 rounded-xl mb-6">
            <IconCode class="w-6 h-6 text-white" />
          </div>
          <h3 class="heading-card mb-3">{t("home.what.software.title")}</h3>
          <p class="text-content-body mb-6">{t("home.what.software.body")}</p>
          <a href={localePath(lang, "/products")} class="link">
            {t("home.what.software.link")}
          </a>
        </div>

        <!-- Talent Services -->
        <div class="card-accent">
          <div class="icon-badge w-12 h-12 bg-brand-green-700 rounded-xl mb-6">
            <IconUsers class="w-6 h-6 text-white" />
          </div>
          <h3 class="heading-card mb-3">{t("home.what.talent.title")}</h3>
          <p class="text-content-body mb-6">{t("home.what.talent.body")}</p>
          <a href={localePath(lang, "/services")} class="link">
            {t("home.what.talent.link")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- RoboLab Highlight -->
  <section class="bg-brand-green-700">
    <div class="container-page py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-gold text-sm font-semibold uppercase tracking-wider mb-4">
            {t("home.robolab.eyebrow")}
          </p>
          <h2 class="text-3xl font-bold text-white mb-5">{t("home.robolab.heading")}</h2>
          <p class="text-green-100 text-lg mb-8">{t("home.robolab.body")}</p>
          <div class="flex flex-wrap gap-4">
            <a
              href={localePath(lang, "/products")}
              class="btn-gold"
            >
              {t("home.robolab.cta.see")}
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { key: "home.robolab.feature.fast",          icon: "⚡" },
            { key: "home.robolab.feature.config",        icon: "🔧" },
            { key: "home.robolab.feature.observability", icon: "📊" },
            { key: "home.robolab.feature.team",          icon: "🤝" },
          ].map(({ key, icon }) => (
            <div class="bg-brand-green-600 rounded-xl p-5 text-center">
              <div class="text-2xl mb-2">{icon}</div>
              <p class="text-white text-sm font-medium">{t(key as any)}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
