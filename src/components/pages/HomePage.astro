---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout
  title="LottaComs"
  description={t("home.meta.description")}
  lang={lang}
>
  <!-- Hero -->
  <section class="bg-brand-green-50">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-brand-green-600 uppercase tracking-wider mb-4">
          {t("home.hero.eyebrow")}
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
          {t("home.hero.heading").split("\n").map((line, i) => (
            <>{i > 0 && <br />}{line}</>
          ))}
        </h1>
        <p class="text-xl text-gray-600 mb-10 max-w-xl">
          {t("home.hero.body")}
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={localePath(lang, "/contact")}
            class="inline-block bg-brand-green-700 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-green-800 transition-colors"
          >
            {t("home.hero.cta.contact")}
          </a>
          <a
            href={localePath(lang, "/products")}
            class="inline-block border-2 border-brand-green-600 text-brand-green-700 font-semibold px-6 py-3 rounded-lg hover:bg-brand-green-100 transition-colors"
          >
            {t("home.hero.cta.products")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="text-center mb-12">
        <p class="text-sm font-medium text-brand-green-600 uppercase tracking-wider mb-3">
          {t("home.what.eyebrow")}
        </p>
        <h2 class="text-3xl font-bold text-gray-900">{t("home.what.heading")}</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Software Products -->
        <div class="bg-brand-green-50 rounded-2xl p-8 border border-brand-green-100">
          <div class="w-12 h-12 bg-brand-green-700 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{t("home.what.software.title")}</h3>
          <p class="text-gray-600 mb-6">{t("home.what.software.body")}</p>
          <a href={localePath(lang, "/products")} class="text-brand-green-700 font-semibold text-sm hover:underline">
            {t("home.what.software.link")}
          </a>
        </div>

        <!-- Talent Services -->
        <div class="bg-brand-green-50 rounded-2xl p-8 border border-brand-green-100">
          <div class="w-12 h-12 bg-brand-green-700 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{t("home.what.talent.title")}</h3>
          <p class="text-gray-600 mb-6">{t("home.what.talent.body")}</p>
          <a href={localePath(lang, "/services")} class="text-brand-green-700 font-semibold text-sm hover:underline">
            {t("home.what.talent.link")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Robolab Highlight -->
  <section class="bg-brand-green-700">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-gold text-sm font-semibold uppercase tracking-wider mb-4">
            {t("home.robolab.eyebrow")}
          </p>
          <h2 class="text-3xl font-bold text-white mb-5">{t("home.robolab.heading")}</h2>
          <p class="text-green-100 text-lg mb-8">{t("home.robolab.body")}</p>
          <div class="flex flex-wrap gap-4">
            <a
              href={localePath(lang, "/products")}
              class="inline-block bg-brand-gold text-brand-green-800 font-semibold px-6 py-3 rounded-lg hover:bg-brand-gold-dark transition-colors"
            >
              {t("home.robolab.cta.see")}
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { key: "home.robolab.feature.fast",          icon: "⚡" },
            { key: "home.robolab.feature.config",        icon: "🔧" },
            { key: "home.robolab.feature.observability", icon: "📊" },
            { key: "home.robolab.feature.team",          icon: "🤝" },
          ].map(({ key, icon }) => (
            <div class="bg-brand-green-600 rounded-xl p-5 text-center">
              <div class="text-2xl mb-2">{icon}</div>
              <p class="text-white text-sm font-medium">{t(key as any)}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
