---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";
import { getJobs } from "../../lib/jobs";
import JobSearch from "../JobSearch";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const jobs = getJobs();
const jobsBasePath = localePath(lang, "/jobs");
---

<BaseLayout
  title={t("jobs.meta.title")}
  description={t("jobs.meta.description")}
  lang={lang}
>
  <!-- Header -->
  <section class="section-header">
    <div class="container-page py-16">
      <p
        class="eyebrow mb-3"
      >
        {t("jobs.header.eyebrow")}
      </p>
      <h1 class="heading-page mb-4">
        {t("jobs.header.heading")}
      </h1>
      <p class="subtitle-page max-w-2xl">
        {t("jobs.header.body")}
      </p>
    </div>
  </section>

  <!-- Job listings with search -->
  <section class="bg-white">
    <div class="container-page py-16">
      <JobSearch
        client:load
        jobs={jobs}
        lang={lang}
        jobsBasePath={jobsBasePath}
        labels={{
          searchPlaceholder: t("jobs.search.placeholder"),
          noResults: t("jobs.search.noresults"),
          empty: t("jobs.empty"),
          salary: t("jobs.card.salary"),
          location: t("jobs.card.location"),
          viewDetails: t("jobs.card.view"),
          applyNow: t("jobs.card.apply"),
        }}
      />
    </div>
  </section>
</BaseLayout>
