---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";
import type { Job } from "../../lib/jobs";
import IconMapPin from "../icons/IconMapPin.astro";
import IconCurrency from "../icons/IconCurrency.astro";

interface Props {
  lang: Lang;
  job: Job;
}
const { lang, job } = Astro.props;
const t = useTranslations(lang);

const descriptionHtml = job.description ? await marked.parse(job.description) : "";
const requirementsHtml = job.requirements ? await marked.parse(job.requirements) : "";
const benefitsHtml = job.benefits ? await marked.parse(job.benefits) : "";
---

<BaseLayout
  title={job.title}
  description={job.description.slice(0, 160)}
  lang={lang}
>
  <!-- Sticky title bar (hidden until original title scrolls out) -->
  <div
    id="sticky-title"
    class="fixed top-16 left-0 right-0 z-40 bg-white border-b border-divider -translate-y-full opacity-0 transition-all duration-200 pointer-events-none"
  >
    <div class="container-page py-3 flex items-center justify-between gap-4">
      <div class="flex items-center gap-4 min-w-0">
        <h2 class="text-lg font-bold text-content truncate">{job.title}</h2>
        <div class="hidden sm:flex items-center gap-4 text-sm text-content-muted shrink-0">
          {job.location && (
            <span class="flex items-center gap-1">
              <IconMapPin class="w-3.5 h-3.5 text-content-subtle" />
              {job.location}
            </span>
          )}
          {job.salary && (
            <span class="flex items-center gap-1">
              <IconCurrency class="w-3.5 h-3.5 text-content-subtle" />
              {job.salary}
            </span>
          )}
        </div>
      </div>
      <a
        href="#apply"
        class="btn-sm shrink-0"
      >
        {t("jobs.detail.apply")}
      </a>
    </div>
  </div>

  <section class="section-header">
    <div class="container-page py-16">
      <a
        href={localePath(lang, "/jobs")}
        class="link mb-4 inline-block"
      >
        {t("jobs.detail.back")}
      </a>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-3">
          <h1 id="job-title" class="heading-page">{job.title}</h1>
          <a
            href="#apply"
            class="btn-primary shrink-0"
          >
            {t("jobs.detail.apply")}
          </a>
        </div>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-content-body mb-4">
          {job.location && (
            <span class="flex items-center gap-1.5">
              <IconMapPin class="w-5 h-5 text-content-subtle" />
              {job.location}
            </span>
          )}
          {job.salary && (
            <span class="flex items-center gap-1.5">
              <IconCurrency class="w-5 h-5 text-content-subtle" />
              {job.salary}
            </span>
          )}
        </div>
        {job.summary && (
          <p class="subtitle-page">{job.summary}</p>
        )}
        {job.tags && job.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {job.tags.map((tag) => (
              <span class="tag text-sm leading-snug">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 py-16 space-y-12">
      {
        descriptionHtml && (
          <div>
            <h2 class="heading-sub mb-4">
              {t("jobs.detail.description")}
            </h2>
            <div
              class="prose prose-gray max-w-none"
              set:html={descriptionHtml}
            />
          </div>
        )
      }

      {
        requirementsHtml && (
          <div>
            <h2 class="heading-sub mb-4">
              {t("jobs.detail.requirements")}
            </h2>
            <div
              class="prose prose-gray max-w-none"
              set:html={requirementsHtml}
            />
          </div>
        )
      }

      {
        benefitsHtml && (
          <div>
            <h2 class="heading-sub mb-4">
              {t("jobs.detail.benefits")}
            </h2>
            <div class="prose prose-gray max-w-none" set:html={benefitsHtml} />
          </div>
        )
      }

      <div id="apply" class="pt-4 scroll-mt-36">
        <h2 class="heading-sub mb-6">
          {t("jobs.apply.heading")}
        </h2>
        <form
          method="POST"
          action="/api/apply"
          enctype="multipart/form-data"
          class="space-y-6"
        >
          <input type="text" name="_gotcha" style="display:none" />
          <input type="hidden" name="_subject" value={`Job application: ${job.title}`} />
          <input type="hidden" name="position" value={job.title} />
          <input type="hidden" name="job_number" value={job.slug} />

          <!-- Name -->
          <div>
            <label
              for="name"
              class="block text-sm font-medium text-content-label mb-2"
            >
              {t("jobs.apply.name")}
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              placeholder={t("jobs.apply.name.ph")}
              class="input-field"
            />
          </div>

          <!-- Email -->
          <div>
            <label
              for="email"
              class="block text-sm font-medium text-content-label mb-2"
            >
              {t("jobs.apply.email")}
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder={t("jobs.apply.email.ph")}
              class="input-field"
            />
          </div>

          <!-- Message -->
          <div>
            <label
              for="message"
              class="block text-sm font-medium text-content-label mb-2"
            >
              {t("jobs.apply.message")}
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder={t("jobs.apply.message.ph")}
              class="input-field resize-none"
            ></textarea>
          </div>

          <!-- Attachments -->
          <div>
            <label
              for="attachment"
              class="block text-sm font-medium text-content-label mb-2"
            >
              {t("jobs.apply.attachment")}
            </label>
            <input
              type="file"
              id="attachment"
              name="attachment"
              multiple
              accept=".pdf,.doc,.docx,.txt,.rtf,.odt,.png,.jpg,.jpeg"
              class="w-full text-sm text-content-body file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand-green-50 file:text-brand-green-700 hover:file:bg-brand-green-100 file:cursor-pointer file:transition-colors"
            />
            <p class="mt-1.5 text-xs text-content-subtle">
              {t("jobs.apply.attachment.hint")}
            </p>
          </div>

          <button
            type="submit"
            class="btn-primary w-full"
          >
            {t("jobs.apply.submit")}
          </button>
        </form>
      </div>
    </div>
  </section>

  <script>
    let observer: IntersectionObserver | undefined;

    document.addEventListener("astro:page-load", () => {
      observer?.disconnect();

      const title = document.getElementById("job-title");
      const sticky = document.getElementById("sticky-title");
      if (title && sticky) {
        observer = new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) {
              sticky.classList.add("-translate-y-full", "opacity-0", "pointer-events-none");
              sticky.classList.remove("translate-y-0", "opacity-100", "pointer-events-auto");
            } else {
              sticky.classList.remove("-translate-y-full", "opacity-0", "pointer-events-none");
              sticky.classList.add("translate-y-0", "opacity-100", "pointer-events-auto");
            }
          },
          { rootMargin: "-64px 0px 0px 0px" },
        );
        observer.observe(title);
      }
    });
  </script>
</BaseLayout>
