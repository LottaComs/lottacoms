---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout
  title={t("contact.meta.title")}
  description={t("contact.meta.description")}
  lang={lang}
>
  <!-- Header -->
  <section class="bg-brand-green-50 border-b border-brand-green-100">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p
        class="text-sm font-medium text-brand-green-600 uppercase tracking-wider mb-3"
      >
        {t("contact.header.eyebrow")}
      </p>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        {t("contact.header.heading")}
      </h1>
      <p class="text-xl text-gray-600 max-w-xl">{t("contact.header.body")}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-16">
        <!-- Contact form -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-8">
            {t("contact.form.heading")}
          </h2>
          <form
            method="POST"
            action="/api/contact"
            class="space-y-6"
          >
            <input type="text" name="_gotcha" style="display:none" />

            <div>
              <label
                for="name"
                class="block text-sm font-medium text-gray-700 mb-2"
              >
                {t("contact.form.name")}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder={t("contact.form.name.ph")}
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-green-500 focus:border-transparent transition"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-gray-700 mb-2"
              >
                {t("contact.form.email")}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder={t("contact.form.email.ph")}
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-green-500 focus:border-transparent transition"
              />
            </div>

            <div>
              <label
                for="topic"
                class="block text-sm font-medium text-gray-700 mb-2"
              >
                {t("contact.form.topic")}
              </label>
              <select
                id="topic"
                name="topic"
                required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-brand-green-500 focus:border-transparent transition"
              >
                <option value="" disabled selected
                  >{t("contact.form.topic.ph")}</option
                >
                <option value="products"
                  >{t("contact.form.topic.products")}</option
                >
                <option value="talent">{t("contact.form.topic.talent")}</option>
                <option value="other">{t("contact.form.topic.other")}</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-gray-700 mb-2"
              >
                {t("contact.form.message")}
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder={t("contact.form.message.ph")}
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-green-500 focus:border-transparent transition resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-brand-green-700 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-green-800 transition-colors"
            >
              {t("contact.form.submit")}
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="md:pt-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-8">
            {t("contact.other.heading")}
          </h2>

          <div class="space-y-8">
            <!-- Email -->
            <div class="flex gap-4 items-start">
              <div
                class="w-10 h-10 bg-brand-green-100 rounded-lg flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-brand-green-700"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">
                  {t("contact.email.title")}
                </p>
                <p class="text-gray-600 text-sm mb-1">
                  {t("contact.email.body")}
                </p>
                <a
                  href="mailto:info@lottacoms.com"
                  class="text-brand-green-700 font-medium text-sm hover:underline"
                >
                  info@lottacoms.com
                </a>
              </div>
            </div>

            <!-- LinkedIn - Founder 1 -->
            <div class="flex gap-4 items-start">
              <div
                class="w-10 h-10 bg-brand-green-100 rounded-lg flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-brand-green-700"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">
                  {t("contact.li1.title")}
                </p>
                <p class="text-gray-600 text-sm mb-1">
                  {t("contact.li1.body")}
                </p>
                <a
                  href="https://www.linkedin.com/in/nguyenhuubaotrung"
                  class="text-brand-green-700 font-medium text-sm hover:underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  linkedin.com/in/nguyenhuubaotrung
                </a>
              </div>
            </div>

            <!-- LinkedIn - Founder 2 -->
            <div class="flex gap-4 items-start">
              <div
                class="w-10 h-10 bg-brand-green-100 rounded-lg flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-brand-green-700"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">
                  {t("contact.li2.title")}
                </p>
                <p class="text-gray-600 text-sm mb-1">
                  {t("contact.li2.body")}
                </p>
                <a
                  href="https://www.facebook.com/nguyenhuubaotrung88"
                  class="text-brand-green-700 font-medium text-sm hover:underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  facebook.com/nguyenhuubaotrung88
                </a>
              </div>
            </div>
          </div>

          <!-- Response time note -->
          <div
            class="mt-12 bg-brand-green-50 rounded-xl p-6 border border-brand-green-100"
          >
            <p class="text-sm text-gray-600 leading-relaxed">
              <span class="font-semibold text-gray-900"
                >{t("contact.note.headsup")}</span
              >{" "}
              {t("contact.note.body")}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
