---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";
import IconMail from "../icons/IconMail.astro";
import IconLinkedIn from "../icons/IconLinkedIn.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout
  title={t("contact.meta.title")}
  description={t("contact.meta.description")}
  lang={lang}
>
  <!-- Header -->
  <section class="section-header">
    <div class="container-page py-16">
      <p
        class="eyebrow mb-3"
      >
        {t("contact.header.eyebrow")}
      </p>
      <h1 class="heading-page mb-4">
        {t("contact.header.heading")}
      </h1>
      <p class="subtitle-page max-w-xl">{t("contact.header.body")}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-page py-20">
      <div class="grid md:grid-cols-2 gap-16">
        <!-- Contact form -->
        <div>
          <h2 class="heading-sub mb-8">
            {t("contact.form.heading")}
          </h2>
          <form
            method="POST"
            action="/api/contact"
            class="space-y-6"
          >
            <input type="text" name="_gotcha" style="display:none" />

            <div>
              <label
                for="name"
                class="block text-sm font-medium text-content-label mb-2"
              >
                {t("contact.form.name")}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder={t("contact.form.name.ph")}
                class="input-field"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-content-label mb-2"
              >
                {t("contact.form.email")}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder={t("contact.form.email.ph")}
                class="input-field"
              />
            </div>

            <div>
              <label
                for="topic"
                class="block text-sm font-medium text-content-label mb-2"
              >
                {t("contact.form.topic")}
              </label>
              <select
                id="topic"
                name="topic"
                required
                class="input-field"
              >
                <option value="" disabled selected
                  >{t("contact.form.topic.ph")}</option
                >
                <option value="products"
                  >{t("contact.form.topic.products")}</option
                >
                <option value="talent">{t("contact.form.topic.talent")}</option>
                <option value="other">{t("contact.form.topic.other")}</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-content-label mb-2"
              >
                {t("contact.form.message")}
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder={t("contact.form.message.ph")}
                class="input-field resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary w-full"
            >
              {t("contact.form.submit")}
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="md:pt-16">
          <h2 class="heading-sub mb-8">
            {t("contact.other.heading")}
          </h2>

          <div class="space-y-8">
            <!-- Email -->
            <div class="flex gap-4 items-start">
              <div
                class="icon-badge w-10 h-10 bg-brand-green-100 rounded-lg"
              >
                <IconMail class="w-5 h-5 text-brand-green-700" />
              </div>
              <div>
                <p class="font-semibold text-content mb-1">
                  {t("contact.email.title")}
                </p>
                <p class="text-content-body text-sm mb-1">
                  {t("contact.email.body")}
                </p>
                <a
                  href="mailto:info@lottacoms.com"
                  class="link"
                >
                  info@lottacoms.com
                </a>
              </div>
            </div>

            <!-- LinkedIn - Founder 1 -->
            <div class="flex gap-4 items-start">
              <div
                class="icon-badge w-10 h-10 bg-brand-green-100 rounded-lg"
              >
                <IconLinkedIn class="w-5 h-5 text-brand-green-700" />
              </div>
              <div>
                <p class="font-semibold text-content mb-1">
                  {t("contact.li1.title")}
                </p>
                <p class="text-content-body text-sm mb-1">
                  {t("contact.li1.body")}
                </p>
                <a
                  href="https://www.linkedin.com/in/nguyenhuubaotrung"
                  class="link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  linkedin.com/in/nguyenhuubaotrung
                </a>
              </div>
            </div>

            <!-- LinkedIn - Founder 2 -->
            <div class="flex gap-4 items-start">
              <div
                class="icon-badge w-10 h-10 bg-brand-green-100 rounded-lg"
              >
                <IconLinkedIn class="w-5 h-5 text-brand-green-700" />
              </div>
              <div>
                <p class="font-semibold text-content mb-1">
                  {t("contact.li2.title")}
                </p>
                <p class="text-content-body text-sm mb-1">
                  {t("contact.li2.body")}
                </p>
                <a
                  href="https://www.facebook.com/nguyenhuubaotrung88"
                  class="link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  facebook.com/nguyenhuubaotrung88
                </a>
              </div>
            </div>
          </div>

          <!-- Response time note -->
          <div
            class="mt-12 section-accent rounded-xl p-6 border"
          >
            <p class="body-sm">
              <span class="font-semibold text-content"
                >{t("contact.note.headsup")}</span
              >{" "}
              {t("contact.note.body")}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
